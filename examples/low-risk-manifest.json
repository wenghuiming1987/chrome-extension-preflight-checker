{
  "manifest_version": 3,
  "name": "Preflight Low Risk Sample",
  "description": "A minimal MV3 extension manifest with intentionally low-risk settings.",
  "version": "1.0.0",
  "action": {
    "default_title": "Preflight Checker"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://example.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://example.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "help/guide.html",
        "styles/panel.css"
      ],
      "matches": [
        "https://example.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
